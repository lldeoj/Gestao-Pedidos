# ============================================
# Configurações da API GestaoPedidos
# ============================================
# Copie este arquivo para .env e configure

# Ambiente de execução
# Valores: Development, Production, Staging
ASPNETCORE_ENVIRONMENT=Production

# URLs da aplicação
ASPNETCORE_URLS=http://+:8080

# ============================================
# Banco de Dados SQLite
# ============================================
# Caminho do arquivo de banco de dados
DB_CONNECTION_STRING=Data Source=/app/data/orders.db

# ============================================
# Configurações JWT
# ============================================
# IMPORTANTE: Altere JWT_KEY para um valor seguro em produção!
JWT_KEY=SuperSecretKeyForJWT@2024!@#$%123456

# Emissor do token (deve ser igual na geração e validação)
JWT_ISSUER=GestaoPedidos.Service

# Público alvo do token
JWT_AUDIENCE=GestaoPedidos.Service

# Tempo de expiração em horas
JWT_EXPIRATION_HOURS=8

# ============================================
# Logging
# ============================================
# Nível de log: Trace, Debug, Information, Warning, Error, Critical, None
LOG_LEVEL=Information

# ============================================
# Docker Compose
# ============================================
# Nome do projeto
COMPOSE_PROJECT_NAME=gestao-pedidos

# BuildKit para builds mais rápidas
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
